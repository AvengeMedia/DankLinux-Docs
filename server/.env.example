GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_MOD_TOKEN=
PLUGIN_MOD_ORG=AvengeMedia
PLUGIN_MOD_TEAM=plugin-moderators
DISCORD_WEBHOOK_URL=
UPLOAD_TOKEN=
UPLOAD_DIR=/data/uploads
CACHE_DIR=/data/cache

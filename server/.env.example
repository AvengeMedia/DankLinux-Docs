PORT=8337
ENVIRONMENT=development
GITHUB_TOKEN=
POEDITOR_CALLBACK_SECRET=
GITHUB_WEBHOOK_SECRET=
# Moderation auth: prefer a GitHub App (actions attributed to the App bot).
